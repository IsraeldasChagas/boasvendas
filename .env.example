APP_NAME="Vendaffacil"
# Nome exibido no site (títulos, navbar, rodapé). Sobrepõe APP_NAME após config:cache.
VENDAFFACIL_SITE_NAME=Vendaffacil
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://vendaffacil.com.br

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=

# Exemplo hospedagem remota (valores reais só no .env local, não commite):
# DB_HOST=186.209.113.112
# DB_DATABASE=grup1285_vendaffacil
# DB_USERNAME=grup1285_userisrael
# DB_PASSWORD="sua_senha_aqui"

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# null em site único. 419 após login: use o mesmo host em APP_URL que no browser (com/sem www) e HTTPS.
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Painel master: e-mails permitidos em /admin (separados por vírgula). Vazio = usa master@vendaffacil.com.br (demo).
VENDAFFACIL_ADMIN_EMAILS=master@vendaffacil.com.br
# Legado (opcional): variável antiga ainda lida se VENDAFFACIL_ADMIN_EMAILS estiver vazio (não renomear no .env antigo)

# ---------------------------------------------------------------------------
# Google Maps Platform (opcional — frete por distância / mapas no futuro)
# ---------------------------------------------------------------------------
# Crie um projeto em https://console.cloud.google.com/ → APIs e serviços → Credenciais → chave de API.
# Habilite a Distance Matrix API (cálculo de rota/km no servidor). Geocoding API é opcional aqui.
# Se for exibir mapa no site, habilite também Maps JavaScript API e restrinja a chave por HTTP referrer.
# A chave fica SOMENTE no .env do servidor (quem hospeda o Vendaffacil), não no painel da loja.
GOOGLE_MAPS_API_KEY=
# Endereço completo de origem das entregas (opcional; reserva para cálculo por km a partir da loja).
# Ex.: "Rua das Flores, 100 - Centro, São Paulo - SP, 01000-000"
GOOGLE_MAPS_DEFAULT_ORIGIN_ADDRESS=
